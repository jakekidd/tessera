{
  "name": "tessera",
  "version": "0.1.0",
  "description": "Browser-canvas ASCII component framework. Each character cell is a tessera; compose them into mosaics.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "demo": "vite demo",
    "demo:build": "vite build --config demo/vite.config.ts",
    "docs": "vitepress dev docs",
    "docs:build": "vite build --config demo/vite.config.ts && vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "typescript": "~5.9.3",
    "vite": "^7.2.2",
    "vitepress": "^1.6.3"
  },
  "license": "MIT",
  "keywords": ["tui", "terminal", "canvas", "ascii", "retro", "dashboard", "ui"]
}
