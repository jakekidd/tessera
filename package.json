{
  "name": "graticule",
  "version": "0.1.0",
  "description": "Browser-canvas ASCII component framework. Zero dependencies. Render character grids, compose layouts, overlay vector graphics.",
  "author": "jakekidd",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jakekidd/graticule.git"
  },
  "homepage": "https://jakekidd.github.io/graticule/",
  "bugs": {
    "url": "https://github.com/jakekidd/graticule/issues"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "demo": "vite demo",
    "demo:build": "vite build --config demo/vite.config.ts",
    "docs": "vitepress dev docs",
    "docs:build": "vite build --config demo/vite.config.ts && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepublishOnly": "tsc"
  },
  "devDependencies": {
    "typescript": "~5.9.3",
    "vite": "^7.2.2",
    "vitepress": "^1.6.3"
  },
  "keywords": [
    "tui",
    "terminal",
    "canvas",
    "ascii",
    "retro",
    "dashboard",
    "ui",
    "component",
    "charcanvas",
    "monospace",
    "grid",
    "chart",
    "graph",
    "browser",
    "zero-dependency"
  ]
}
